# Base de datos
DATABASE_URL=postgresql://user:password@localhost:5432/forogaming

# JWT
JWT_SECRET=your-secret-key-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# Storage S3-compatible
# TODO: Configurar cuando se elija proveedor (Cloudflare R2, Supabase Storage, AWS S3)
S3_BUCKET=forogaming-media
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_PUBLIC_URL=

# CORS
ALLOWED_ORIGINS=http://localhost:3000
